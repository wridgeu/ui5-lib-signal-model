<mvc:View
	controllerName="demo.app.controller.TreeBinding"
	xmlns:mvc="sap.ui.core"
	xmlns="sap.m">
	<Panel headerText="Tree Binding Demo" class="sapUiContentPadding">
		<Tree id="orgTree" items="{path: 'tree>/org', parameters: {arrayNames: ['reports']}}">
			<StandardTreeItem title="{tree>name}" description="{tree>role}" />
		</Tree>
		<Button text="Add Employee" press=".onAddEmployee" class="sapUiSmallMargin" />
		<MessageStrip
			text="Tree binding uses SignalModel with arrayNames parameter. Expanding nodes traverses the signal-backed data hierarchy."
			type="Information"
			class="sapUiSmallMargin" />
	</Panel>
</mvc:View>
